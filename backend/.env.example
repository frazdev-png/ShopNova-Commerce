# Database (SQLite local, PostgreSQL production)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/ecommerce
DATABASE_URL=sqlite+aiosqlite:///./ecommerce.db

# JWT
SECRET_KEY=your-secret-key-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# App
APP_NAME=Ecommerce API
APP_VERSION=1.0.0
APP_DEBUG=false

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
RATE_LIMIT_LOGIN_REQUESTS=10
RATE_LIMIT_LOGIN_WINDOW=60

# Password Policy
MIN_PASSWORD_LENGTH=8
MIN_PASSWORD_UPPERCASE=1
MIN_PASSWORD_LOWERCASE=1
MIN_PASSWORD_DIGITS=1
MIN_PASSWORD_SPECIAL=0
